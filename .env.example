# ============================================================
# Text-to-SQL AI Agent 环境变量配置示例
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填写以下所有环境变量的实际值
# 3. 确保 .env 文件不被提交到版本控制（已配置在 .gitignore 中）
# ============================================================

# ------------------------------------------------------------
# LLM API 配置（必需）
# ------------------------------------------------------------
# 阿里云 DashScope API Key（通义千问大模型）
# 获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ------------------------------------------------------------
# LangSmith 追踪配置（可选，用于调试和监控）
# ------------------------------------------------------------
# LangSmith API Key，用于追踪和调试 Agent 执行流程
# 获取地址：https://smith.langchain.com/
LANGSMITH_API_KEY=your-langsmith-api-key-here

# 是否启用 LangSmith 追踪（true/false）
LANGSMITH_TRACING=true

# LangSmith 项目名称
LANGSMITH_PROJECT=ai-agent

# ------------------------------------------------------------
# 数据库配置（必需）
# ------------------------------------------------------------
# MySQL 数据库主机地址
DB_HOST=127.0.0.1

# MySQL 数据库端口
DB_PORT=3306

# MySQL 数据库名称
DB_NAME=your_database_name

# MySQL 数据库用户名
DB_USER=your_database_username

# MySQL 数据库密码
DB_PASSWORD=your_database_password

# ------------------------------------------------------------
# 其他可选配置
# ------------------------------------------------------------
# 智谱 AI API Key（如需使用智谱模型）
# ZHIPUAI_API_KEY=your-zhipuai-api-key-here
